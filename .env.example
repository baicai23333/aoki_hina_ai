DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_IPS=
TTS_HOME=/home/mutsumi/aoki_hina_ai/.tts_models

AOKI_TTS_ENABLED=1
AOKI_TTS_BACKEND=gpt_sovits
AOKI_TTS_MODEL_NAME=
AOKI_TTS_CACHE_DIR=/home/mutsumi/aoki_hina_ai/tts_cache
AOKI_TTS_MAX_CHARS=400

GPT_SOVITS_API_URL=http://127.0.0.1:9880/tts
GPT_SOVITS_AUTO_START=1
GPT_SOVITS_ROOT=D:\path\to\GPT-SoVITS
GPT_SOVITS_REFERENCE_AUDIO=D:\path\to\reference.wav
GPT_SOVITS_REFERENCE_TEXT=replace_with_the_exact_reference_transcript
GPT_SOVITS_PROMPT_LANGUAGE=ja
GPT_SOVITS_OUTPUT_LANGUAGE=ja
GPT_SOVITS_TIMEOUT=180
GPT_SOVITS_NORMALIZE_LOUDNESS=1
GPT_SOVITS_TARGET_LUFS=-16

AOKI_XTTS_SPEAKER_NAME=MyVoice
AOKI_XTTS_LANGUAGE=ja
AOKI_XTTS_USE_CACHED_VOICE=1
AOKI_XTTS_REFS_MANIFEST=/home/mutsumi/aoki_hina_ai/tts_xtts/refs/refs_manifest.json
